# TEMPLATE — copy to .env.local and fill in values.
# .env.local is git-ignored; never commit real keys.
# This file (.env.example) IS committed and must contain placeholders only.

# ---- Supabase ---------------------------------------------------------------
# Get these from https://supabase.com/dashboard/project/<project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — never expose to the browser, never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Mapbox -----------------------------------------------------------------
# Public token (starts with pk.) — restrict to your domains in the Mapbox dashboard.
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# ---- Moovon Lotus draw-results sync ----------------------------------------
# Powers the cron at /api/cron/sync-results. The cron pulls /draw/checkDraw
# every 15 min on EC2 and upserts new draws into Supabase.
#
# LOTUS_API_BASE_URL — HTTP (not HTTPS) until the Lotus team adds TLS.
#                      Only safe when called from a trusted network.
# LOTUS_API_TOKEN    — Sanctum-style bearer token from the Lotus team.
# CRON_SECRET        — Random 32+ char string. Must match the value used in
#                      admin's crontab on EC2 to authenticate the cron call.
LOTUS_API_BASE_URL=http://18.119.94.68/api
LOTUS_API_TOKEN=
CRON_SECRET=
